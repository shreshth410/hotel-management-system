<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="720.0" prefWidth="840.0" spacing="30.0" styleClass="view-pane" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.controllers.DashboardController">
   <children>
      <Label styleClass="view-title" text="Hotel Dashboard" />
      <HBox spacing="20.0" VBox.vgrow="NEVER">
         <children>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="stat-title" text="Total Rooms" />
                  <Label fx:id="totalRoomsLbl" styleClass="stat-value" text="0" />
               </children>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="stat-title" text="Available Rooms" />
                  <Label fx:id="availableRoomsLbl" styleClass="stat-value" text="0" />
               </children>
            </VBox>
         </children>
      </HBox>
      <HBox spacing="20.0">
         <children>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="stat-title" text="Total Customers" />
                  <Label fx:id="totalCustomersLbl" styleClass="stat-value" text="0" />
               </children>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="stat-title" text="Active Bookings" />
                  <Label fx:id="activeBookingsLbl" styleClass="stat-value" text="0" />
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</VBox>
